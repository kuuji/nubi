# Copy to .env and fill in real values
# Used by: make cluster-up (creates K8s secret), make dev (controller env)

GITHUB_TOKEN=ghp_your_token_here
LLM_API_KEY=sk-or-your-openrouter-key-here

# LLM provider: anthropic, bedrock, openai (use openai for OpenRouter)
NUBI_LLM_PROVIDER=openai

# Model ID (OpenRouter format for Kimi K2)
NUBI_MODEL_ID=moonshotai/kimi-k2

# Base URL for OpenAI-compatible endpoints (OpenRouter, ollama, etc.)
NUBI_LLM_BASE_URL=https://openrouter.ai/api/v1
